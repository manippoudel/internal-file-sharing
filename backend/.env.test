# Test Environment Configuration
# This file is used when running tests

# Application
APP_NAME="Internal File Sharing System - Test"
APP_VERSION="1.0.0"
DEBUG=True

# Database (Test Database)
DATABASE_URL="postgresql+asyncpg://testuser:testpassword@localhost:5433/filedb_test"

# Security (Test values - NOT for production)
SECRET_KEY="test-secret-key-for-testing-only-do-not-use-in-production"
ALGORITHM="HS256"
SESSION_EXPIRE_MINUTES=30
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# File Upload
MAX_UPLOAD_SIZE=10737418240  # 10 GB
CHUNK_SIZE=52428800  # 50 MB
MAX_CONCURRENT_UPLOADS=3
MAX_CONCURRENT_DOWNLOADS=5

# File Storage (Test paths)
STORAGE_PATH="/tmp/test_data"
ACTIVE_FILES_PATH="/tmp/test_data/active"
DELETED_FILES_PATH="/tmp/test_data/deleted"
TEMP_FILES_PATH="/tmp/test_data/temp"
BACKUP_PATH="/tmp/test_data/backups"
LOGS_PATH="/tmp/test_data/logs"

# Sync Settings (Disabled for tests)
SYNC_ENABLED=False
RCLONE_CONFIG_PATH="/tmp/rclone.conf"
WINDOWS_SERVER_PATH="windows-remote:"

# Scheduler (Disabled for tests)
SCHEDULER_ENABLED=False

# File Retention
DELETED_FILES_RETENTION_DAYS=90

# Pagination
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=100

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://testserver"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Maximum concurrent users
MAX_CONCURRENT_USERS=15
